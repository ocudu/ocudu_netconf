<?xml version="1.0" encoding="UTF-8"?>

<!-- Main CU base config -->
<RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
  <id>rrm_policy1</id>
  <attributes>
    <resourceType>PRB</resourceType>
    <rRMPolicyMemberList>
      <mcc>001</mcc>
      <mnc>01</mnc>
      <sd>ffffff</sd>
      <sst>1</sst>
    </rRMPolicyMemberList>
    <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
    <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
    <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
  </attributes>
</RRMPolicyRatio>

<ManagedElement xmlns="urn:3gpp:sa5:_3gpp-common-managed-element">
  <id>ran1</id>
  <attributes>
    <priorityLabel>1</priorityLabel>
  </attributes>

  <GNBCUCPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcucpfunction">
      <id>cucp1</id>
      <attributes>
        <resourceType>DRB</resourceType>
        <rRMPolicyMemberList>
          <mcc>001</mcc>
          <mnc>01</mnc>
          <sd>ffffff</sd>
          <sst>1</sst>
        </rRMPolicyMemberList>
        <gNBId>1</gNBId>
        <gNBIdLength>24</gNBIdLength>
        <gNBCUName>srscu1</gNBCUName>
        <pLMNId>
          <mcc>001</mcc>
          <mnc>01</mnc>
        </pLMNId>
        <priorityLabel>1</priorityLabel>
      </attributes>

      <PerfMetricJob>
        <id>defaulttrace</id>
        <attributes>
          <administrativeState>UNLOCKED</administrativeState>
          <performanceMetrics>DRB.MaxActiveUeDl</performanceMetrics>
          <granularityPeriod>1</granularityPeriod>
          <!--
          <fileReportingPeriod>10</fileReportingPeriod>
          <fileLocation>/tmp/metrics.json</fileLocation>
          -->
          <streamTarget>http://192.168.2.42:9560/json</streamTarget>
        </attributes>
      </PerfMetricJob>

      <!-- No cell specific CU config required
      <NRCellCU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellcu">
        <id>nrcell1</id>
        <attributes>
         <cellLocalId>100</cellLocalId>
           <pLMNInfoList>
             <mcc>001</mcc>
             <mnc>01</mnc>
             <sd>ffffff</sd>
             <sst>1</sst>
           </pLMNInfoList>
           <priorityLabel>1</priorityLabel>
        </attributes>
      </NRCellCU>
      -->

      <EP_NgC xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
        <id>ngc1</id>
        <attributes>
          <localAddress>
            <ipAddress>10.53.1.1</ipAddress>
            <vlanId>0</vlanId>
          </localAddress>
          <remoteAddress>10.53.1.2</remoteAddress>
        </attributes>
      </EP_NgC>
  </GNBCUCPFunction>

  <GNBCUUPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcuupfunction">
    <id>cuup1</id>
    <attributes>
      <priorityLabel>1</priorityLabel>
      <resourceType>DRB</resourceType>
      <rRMPolicyMemberList>
        <mcc>001</mcc>
        <mnc>01</mnc>
        <sd>ffffff</sd>
        <sst>1</sst>
      </rRMPolicyMemberList>
      <gNBId>1</gNBId>
      <gNBIdLength>24</gNBIdLength>
      <pLMNInfoList>
        <mcc>001</mcc>
        <mnc>01</mnc>
        <sd>ffffff</sd>
        <sst>1</sst>
      </pLMNInfoList>
    </attributes>
  </GNBCUUPFunction>
</ManagedElement>
