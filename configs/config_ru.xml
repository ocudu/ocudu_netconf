    </switching-points>
    <switching-points>
      <switching-point-id>3</switching-point-id>
      <direction>DL</direction>
      <frame-offset>6144000</frame-offset>
    </switching-points>
    <switching-points>
      <switching-point-id>4</switching-point-id>
      <direction>GP</direction>
      <frame-offset>10708114</frame-offset>
    </switching-points>
    <switching-points>
      <switching-point-id>5</switching-point-id>
